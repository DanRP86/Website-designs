import React, { useState, useEffect, useMemo } from 'react';
import { Play, Pause, RotateCcw, TrendingUp, Target, Layers, ArrowRight } from 'lucide-react';

const App = () => {
  const [time, setTime] = useState(0);
  const [isPlaying, setIsPlaying] = useState(false);
  const maxTime = 120; // Total simulation days/units

  // --- CONFIGURATION OF THE TWO MODELS ---
  const config = {
    consultative: {
      timePerCase: 10,
      roiPerCase: 20, // in thousands
      color: '#3B82F6', // blue-500
      bgClass: 'bg-blue-500',
      textClass: 'text-blue-500',
    },
    productized: {
      setupTime: 30,
      setupCost: 40, // in thousands
      timePerCase: 1, // very fast marginal time
      roiPerCase: 5, // smaller marginal ROI
      color: '#8B5CF6', // violet-500
      bgClass: 'bg-violet-500',
      textClass: 'text-violet-500',
    }
  };

  // --- GENERATE DATA POINTS ---
  const data = useMemo(() => {
    const points = [];
    for (let t = 0; t <= maxTime; t++) {
      // Consultative Logic
      const consultCases = Math.floor(t / config.consultative.timePerCase);
      const consultROI = consultCases * config.consultative.roiPerCase;

      // Productized Logic
      let prodCases = 0;
      let prodROI = 0;
      if (t < config.productized.setupTime) {
        // Spending money to build the core product
        prodROI = -(t / config.productized.setupTime) * config.productized.setupCost;
      } else {
        // Core is built, now mass producing
        prodCases = Math.floor((t - config.productized.setupTime) / config.productized.timePerCase);
        prodROI = -config.productized.setupCost + (prodCases * config.productized.roiPerCase);
      }

      points.push({
        time: t,
        consultCases,
        consultROI,
        prodCases,
        prodROI,
      });
    }
    return points;
  }, []);

  // --- ANIMATION LOOP ---
  useEffect(() => {
    let interval;
    if (isPlaying && time < maxTime) {
      interval = setInterval(() => {
        setTime((prev) => Math.min(prev + 1, maxTime));
      }, 50); // Speed of animation
    } else if (time >= maxTime) {
      setIsPlaying(false);
    }
    return () => clearInterval(interval);
  }, [isPlaying, time]);

  const reset = () => {
    setIsPlaying(false);
    setTime(0);
  };

  const currentData = data[time];

  // --- CHART RENDERING HELPERS ---
  const chartWidth = 800;
  const chartHeight = 300;
  const minY = -50;
  const maxY = 450;
  
  const mapX = (t) => (t / maxTime) * chartWidth;
  const mapY = (roi) => chartHeight - ((roi - minY) / (maxY - minY)) * chartHeight;

  // Generate SVG paths up to current time
  const consultPath = data.slice(0, time + 1).map((d, i) => `${i === 0 ? 'M' : 'L'} ${mapX(d.time)} ${mapY(d.consultROI)}`).join(' ');
  const prodPath = data.slice(0, time + 1).map((d, i) => `${i === 0 ? 'M' : 'L'} ${mapX(d.time)} ${mapY(d.prodROI)}`).join(' ');

  return (
    <div className="min-h-screen bg-slate-50 text-slate-800 p-4 md:p-8 font-sans">
      <div className="max-w-6xl mx-auto space-y-6">
        
        {/* Header */}
        <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
          <div>
            <h1 className="text-2xl font-bold flex items-center gap-2">
              <TrendingUp className="text-emerald-500" />
              The Power of Mass Production
            </h1>
            <p className="text-slate-500 mt-1 max-w-2xl">
              ROI Comparison: A bespoke consultative approach (high margin, low volume) vs. a productized approach (initial investment, low unit margin, <b>massive volume</b>).
            </p>
          </div>
          
          {/* Controls */}
          <div className="flex items-center gap-3 bg-slate-50 p-2 rounded-xl border border-slate-200">
            <button 
              onClick={() => setIsPlaying(!isPlaying)}
              className={`flex items-center gap-2 px-4 py-2 rounded-lg font-medium transition-colors ${isPlaying ? 'bg-amber-100 text-amber-700 hover:bg-amber-200' : 'bg-emerald-500 text-white hover:bg-emerald-600'}`}
            >
              {isPlaying ? <Pause size={18} /> : <Play size={18} />}
              {isPlaying ? 'Pause' : time >= maxTime ? 'Finished' : 'Simulate'}
            </button>
            <button 
              onClick={reset}
              className="p-2 text-slate-500 hover:text-slate-700 hover:bg-slate-200 rounded-lg transition-colors"
              title="Reset"
            >
              <RotateCcw size={18} />
            </button>
          </div>
        </div>

        {/* Timeline Slider */}
        <div className="bg-white p-4 rounded-2xl shadow-sm border border-slate-100">
          <div className="flex justify-between text-sm font-medium text-slate-500 mb-2">
            <span>Day 0</span>
            <span className="text-indigo-600 font-bold">Day {time}</span>
            <span>Day {maxTime}</span>
          </div>
          <input 
            type="range" 
            min="0" 
            max={maxTime} 
            value={time} 
            onChange={(e) => {
              setTime(parseInt(e.target.value));
              setIsPlaying(false);
            }}
            className="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
          />
        </div>

        {/* Main Metrics Cards */}
        <div className="grid md:grid-cols-2 gap-6">
          {/* Consultative Card */}
          <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 relative overflow-hidden flex flex-col">
            <div className="absolute top-0 left-0 w-1 h-full bg-blue-500"></div>
            <div className="flex justify-between items-start mb-4">
              <div>
                <h2 className="text-lg font-bold flex items-center gap-2">
                  <Target className="text-blue-500" size={20} />
                  Consultative / Case-by-Case
                </h2>
                <p className="text-sm text-slate-500">Bespoke solutions, slow but steady.</p>
              </div>
            </div>
            <div className="grid grid-cols-2 gap-4 mb-6">
              <div className="bg-slate-50 p-3 rounded-xl border border-slate-100">
                <div className="text-xs text-slate-500 font-medium mb-1">Cumulative ROI</div>
                <div className="text-3xl font-black text-blue-600">${currentData.consultROI}k</div>
              </div>
              <div className="bg-slate-50 p-3 rounded-xl border border-slate-100">
                <div className="text-xs text-slate-500 font-medium mb-1">Cases Implemented</div>
                <div className="text-3xl font-black text-slate-700">{currentData.consultCases}</div>
              </div>
            </div>
            
            {/* Visualizer of Cases */}
            <div className="flex-1 space-y-2 bg-slate-50 p-4 rounded-xl border border-slate-100">
              <div className="text-xs font-semibold text-slate-400 uppercase tracking-wider">Case Volume</div>
              <div className="flex flex-wrap gap-2 min-h-[60px] content-start">
                {Array.from({ length: Math.max(1, data[maxTime].consultCases) }).map((_, i) => (
                  <div 
                    key={i} 
                    className={`w-8 h-8 rounded-md shadow-sm transition-all duration-300 ${i < currentData.consultCases ? 'bg-blue-500 scale-100 opacity-100' : 'bg-slate-200 scale-90 opacity-50'}`}
                    title={`Case ${i+1}`}
                  />
                ))}
              </div>
            </div>
          </div>

          {/* Productized Card */}
          <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 relative overflow-hidden flex flex-col">
            <div className="absolute top-0 left-0 w-1 h-full bg-violet-500"></div>
            <div className="flex justify-between items-start mb-4">
              <div>
                <h2 className="text-lg font-bold flex items-center gap-2">
                  <Layers className="text-violet-500" size={20} />
                  Mass Production
                </h2>
                <p className="text-sm text-slate-500">Standard core + minor adaptations.</p>
              </div>
              {time < config.productized.setupTime && (
                 <span className="px-2 py-1 bg-amber-100 text-amber-700 text-xs font-bold rounded-md animate-pulse">
                   Building Core...
                 </span>
              )}
            </div>
            <div className="grid grid-cols-2 gap-4 mb-6">
              <div className="bg-slate-50 p-3 rounded-xl border border-slate-100">
                <div className="text-xs text-slate-500 font-medium mb-1">Cumulative ROI</div>
                <div className={`text-3xl font-black ${currentData.prodROI < 0 ? 'text-rose-500' : 'text-violet-600'}`}>
                  ${currentData.prodROI}k
                </div>
              </div>
              <div className="bg-slate-50 p-3 rounded-xl border border-slate-100">
                <div className="text-xs text-slate-500 font-medium mb-1">Cases Implemented</div>
                <div className="text-3xl font-black text-slate-700">{currentData.prodCases}</div>
              </div>
            </div>

            {/* Visualizer of Cases */}
            <div className="flex-1 space-y-2 bg-slate-50 p-4 rounded-xl border border-slate-100">
              <div className="text-xs font-semibold text-slate-400 uppercase tracking-wider">Case Volume</div>
              <div className="flex flex-wrap gap-1 min-h-[60px] content-start">
                {time < config.productized.setupTime ? (
                  <div className="w-full h-8 bg-slate-200 rounded-md overflow-hidden flex relative shadow-inner">
                     <div 
                        className="bg-violet-400 h-full absolute left-0 top-0 transition-all duration-200"
                        style={{ width: `${(time / config.productized.setupTime) * 100}%` }}
                     />
                     <span className="relative z-10 w-full text-center text-xs font-bold text-violet-900 leading-8 mix-blend-color-burn">Initial Investment Phase (Systematizing)</span>
                  </div>
                ) : (
                  Array.from({ length: data[maxTime].prodCases }).map((_, i) => (
                    <div 
                      key={i} 
                      className={`w-4 h-4 rounded-sm shadow-sm transition-all duration-300 ${i < currentData.prodCases ? 'bg-violet-500 scale-100 opacity-100' : 'bg-slate-200 scale-90 opacity-50'}`}
                    />
                  ))
                )}
              </div>
            </div>
          </div>
        </div>

        {/* Chart Section */}
        <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
          <h3 className="text-lg font-bold mb-6 text-center">Cumulative ROI Evolution Over Time</h3>
          
          <div className="relative w-full overflow-hidden" style={{ paddingBottom: '37.5%' }}>
            <svg 
              viewBox={`0 0 ${chartWidth} ${chartHeight}`} 
              className="absolute top-0 left-0 w-full h-full overflow-visible"
            >
              {/* Zero Line */}
              <line x1="0" y1={mapY(0)} x2={chartWidth} y2={mapY(0)} stroke="#cbd5e1" strokeWidth="2" strokeDasharray="4 4" />
              <text x="5" y={mapY(0) - 5} fill="#94a3b8" fontSize="12" fontWeight="bold">$0 (Break-even)</text>

              {/* Y Axis Labels */}
              {[100, 200, 300, 400].map(val => (
                <g key={val}>
                  <line x1="0" y1={mapY(val)} x2={chartWidth} y2={mapY(val)} stroke="#f1f5f9" strokeWidth="1" />
                  <text x="5" y={mapY(val) - 5} fill="#cbd5e1" fontSize="10">${val}k</text>
                </g>
              ))}

              {/* Consultative Line */}
              <path 
                d={consultPath} 
                fill="none" 
                stroke={config.consultative.color} 
                strokeWidth="4" 
                strokeLinecap="round" 
                strokeLinejoin="round" 
              />
              {time > 0 && (
                <circle cx={mapX(time)} cy={mapY(currentData.consultROI)} r="6" fill={config.consultative.color} className="transition-all duration-100" />
              )}

              {/* Productized Line */}
              <path 
                d={prodPath} 
                fill="none" 
                stroke={config.productized.color} 
                strokeWidth="4" 
                strokeLinecap="round" 
                strokeLinejoin="round" 
              />
              {time > 0 && (
                <circle cx={mapX(time)} cy={mapY(currentData.prodROI)} r="6" fill={config.productized.color} className="transition-all duration-100" />
              )}
            </svg>
          </div>
          
          <div className="flex justify-center gap-8 mt-6">
            <div className="flex items-center gap-2 text-sm font-medium">
              <div className="w-4 h-4 rounded-full bg-blue-500"></div>
              Consultative (Linear Growth)
            </div>
            <div className="flex items-center gap-2 text-sm font-medium">
              <div className="w-4 h-4 rounded-full bg-violet-500"></div>
              Mass Production (Exponential Growth via Volume)
            </div>
          </div>
        </div>

      </div>
    </div>
  );
};

export default App;
